,\n          imagen: require('@/assets/actividad/imagen3.png'),\n          barajarRespuestas: true,\n          opciones: [\n            {\n              id: 'a',\n              texto: 'Verdadero',\n              esCorrecta: false,\n            },\n            {\n              id: 'b',\n              texto: 'Falso',\n              esCorrecta: true,\n            },\n          ],\n          mensaje_correcto: '¡Muy bien! Ha acertado la respuesta.',\n          mensaje_incorrecto: 'Lo sentimos, su respuesta no es la correcta.',\n        },\n        {\n          id: 10,\n          texto:\n            'La jugosidad de la carne está relacionada con su contenido de agua y grasa.',\n          imagen: require('@/assets/actividad/imagen3.png'),\n          barajarRespuestas: true,\n          opciones: [\n            {\n              id: 'a',\n              texto: 'Verdadero',\n              esCorrecta: true,\n            },\n            {\n              id: 'b',\n              texto: 'Falso',\n              esCorrecta: false,\n            },\n          ],\n          mensaje_correcto: '¡Muy bien! Ha acertado la respuesta.',\n          mensaje_incorrecto: 'Lo sentimos, su respuesta no es la correcta.',\n        },\n        {\n          id: 11,\n          texto:\n            'La mioglobina es la proteína responsable del color rojo en la carne.',\n          imagen: require('@/assets/actividad/imagen3.png'),\n          barajarRespuestas: true,\n          opciones: [\n            {\n              id: 'a',\n              texto: 'Verdadero',\n              esCorrecta: true,\n            },\n            {\n              id: 'b',\n              texto: 'Falso',\n              esCorrecta: false,\n            },\n          ],\n          mensaje_correcto: '¡Muy bien! Ha acertado la respuesta.',\n          mensaje_incorrecto: 'Lo sentimos, su respuesta no es la correcta.',\n        },\n        {\n          id: 12,\n          texto:\n            'El tejido muscular liso se encuentra en los músculos voluntarios del cuerpo.',\n          imagen: require('@/assets/actividad/imagen3.png'),\n          barajarRespuestas: true,\n          opciones: [\n            {\n              id: 'a',\n              texto: 'Verdadero',\n              esCorrecta: true,\n            },\n            {\n              id: 'b',\n              texto: 'Falso',\n              esCorrecta: false,\n            },\n          ],\n          mensaje_correcto: '¡Muy bien! Ha acertado la respuesta.',\n          mensaje_incorrecto: 'Lo sentimos, su respuesta no es la correcta.',\n        },\n        {\n          id: 13,\n          texto: 'La grasa intramuscular no influye en el sabor de la carne.',\n          imagen: require('@/assets/actividad/imagen4.png'),\n          barajarRespuestas: true,\n          opciones: [\n            {\n              id: 'a',\n              texto: 'Verdadero',\n              esCorrecta: true,\n            },\n            {\n              id: 'b',\n              texto: 'Falso',\n              esCorrecta: false,\n            },\n          ],\n          mensaje_correcto: '¡Muy bien! Ha acertado la respuesta.',\n          mensaje_incorrecto: 'Lo sentimos, su respuesta no es la correcta.',\n        },\n        {\n          id: 14,\n          texto:\n            'La carne de cerdo contiene más ácidos grasos insaturados que la carne de res.',\n          imagen: require('@/assets/actividad/imagen4.png'),\n          barajarRespuestas: true,\n          opciones: [\n            {\n              id: 'a',\n              texto: 'Verdadero',\n              esCorrecta: false,\n            },\n            {\n              id: 'b',\n              texto: 'Falso',\n              esCorrecta: true,\n            },\n          ],\n          mensaje_correcto: '¡Muy bien! Ha acertado la respuesta.',\n          mensaje_incorrecto: 'Lo sentimos, su respuesta no es la correcta.',\n        },\n        {\n          id: 15,\n          texto:\n            'La reacción de Maillard es la responsable del desarrollo del aroma de la carne cocida.',\n          imagen: require('@/assets/actividad/imagen4.png'),\n          barajarRespuestas: true,\n          opciones: [\n            {\n              id: 'a',\n              texto: 'Verdadero',\n              esCorrecta: true,\n            },\n            {\n              id: 'b',\n              texto: 'Falso',\n              esCorrecta: false,\n            },\n          ],\n          mensaje_correcto: '¡Muy bien! Ha acertado la respuesta.',\n          mensaje_incorrecto: 'Lo sentimos, su respuesta no es la correcta.',\n        },\n      ],\n      mensaje_final_aprobado: '¡Excelente! Ha superado la actividad.',\n      mensaje_final_reprobado:\n        'Le recomendamos volver a revisar el componente formativo e intentar nuevamente la actividad didáctica.',\n    },\n  }),\n}\n</script>\n"]}]}